{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run List Response",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "url": { "type": "string" },
      "task": { "type": "string" },
      "success": { "type": "boolean" },
      "created_at": { "type": "string", "format": "date-time" }
    },
    "required": ["id", "url", "task", "success", "created_at"]
  }
}
