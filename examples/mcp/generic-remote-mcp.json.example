{
  "name": "browser-proof",
  "version": "1.1.0",
  "description": "Evidence-backed web verification for agents.",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://proof.reprompt.jp/mcp",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "Production Browser Proof API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    },
    {
      "type": "sse",
      "url": "https://proof.reprompt.jp/mcp/sse",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "Production Browser Proof API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
